<UserControl x:Class="RotinaClone.App.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vms="clr-namespace:RotinaClone.App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vms:LogViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Logs Operacionais de Rotina Clone" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Atualizar Logs" Width="120" Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                <Button Content="Limpar Histórico" Background="{DynamicResource ErrorColor}" BorderBrush="{DynamicResource ErrorColor}" Width="120" Command="{Binding ClearLogsCommand}" />
            </StackPanel>
        </Grid>

        <!-- Log Textbox Console Container -->
        <Border Grid.Row="1" Style="{DynamicResource GlassCard}" Padding="15" Background="#15000000">
            <TextBox Text="{Binding LogContent}" FontFamily="Consolas" FontSize="11" 
                     Foreground="{DynamicResource PrimaryAccent}" Background="Transparent" BorderThickness="0" 
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextChanged="TextBox_TextChanged" />
        </Border>
    </Grid>
</UserControl>
