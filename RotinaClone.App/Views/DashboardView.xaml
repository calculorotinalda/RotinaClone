<UserControl x:Class="RotinaClone.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:components="clr-namespace:RotinaClone.App.Components"
             xmlns:vms="clr-namespace:RotinaClone.App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vms:DashboardViewModel}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- System Overview Row -->
            <RowDefinition Height="*" />     <!-- Drives List Section -->
        </Grid.RowDefinitions>

        <!-- System Overview Widgets -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Total Drives Card -->
            <Border Grid.Column="0" Style="{DynamicResource GlassCard}" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total de Discos" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TotalDisksCount, FallbackValue='3'}" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" Margin="0,5" />
                    <TextBlock Text="Dispositivos físicos detetados" Foreground="{DynamicResource TextSecondary}" FontSize="10" />
                </StackPanel>
            </Border>

            <!-- Boot Environment Card -->
            <Border Grid.Column="1" Style="{DynamicResource GlassCard}" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Ambiente de Arranque" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="UEFI Boot" Foreground="{DynamicResource InfoColor}" FontSize="18" FontWeight="Bold" Margin="0,10,0,9" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding BootType, FallbackValue='UEFI Secure Boot'}" Foreground="{DynamicResource TextSecondary}" FontSize="10" />
                </StackPanel>
            </Border>

            <!-- Available Backup Space -->
            <Border Grid.Column="2" Style="{DynamicResource GlassCard}" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Espaço Livre (Total)" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding AvailableSpaceGB, StringFormat='{}{0:F0} GB', FallbackValue='452 GB'}" Foreground="{DynamicResource PrimaryAccent}" FontSize="24" FontWeight="Bold" Margin="0,5" />
                    <TextBlock Text="{Binding TotalSpaceGB, StringFormat='de {0:F0} GB no sistema', FallbackValue='de 1024 GB'}" Foreground="{DynamicResource TextSecondary}" FontSize="10" />
                </StackPanel>
            </Border>

            <!-- Operating System Info -->
            <Border Grid.Column="3" Style="{DynamicResource GlassCard}" Padding="15">
                <StackPanel>
                    <TextBlock Text="Sistema Operativo" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="Windows 11" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,10,0,9" />
                    <TextBlock Text="{Binding OsName, FallbackValue='Windows 11 Pro 23H2'}" Foreground="{DynamicResource TextSecondary}" FontSize="10" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Drives List Section -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Discos Rígidos e Partições Detetadas" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Content="Atualizar" HorizontalAlignment="Right" Width="100" Padding="8,4" FontSize="11" Command="{Binding RefreshCommand}" />
            </Grid>

            <!-- Scrollable list of DiskCards -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                <ItemsControl ItemsSource="{Binding Disks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <components:DiskCard Disk="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
