<UserControl x:Class="RotinaClone.App.Views.BackupManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vms="clr-namespace:RotinaClone.App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vms:BackupManagerViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />  <!-- Main Config Panels -->
            <RowDefinition Height="Auto" /> <!-- Running Backup Progress -->
        </Grid.RowDefinitions>

        <!-- Main Config Panels -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Configured Jobs List (Left) -->
            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Tarefas de Cópia de Segurança Agendadas" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" />
                
                <ListBox Grid.Row="1" ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}" Background="Transparent" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1" Padding="10" Background="Transparent" Width="430">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Bold" />
                                        <TextBlock Text="{Binding SourcePath, StringFormat='Origem: {0}'}" Foreground="{DynamicResource TextSecondary}" FontSize="10" />
                                        <TextBlock Text="{Binding DestinationPath, StringFormat='Destino: {0}'}" Foreground="{DynamicResource TextSecondary}" FontSize="10" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Border Background="#15FF8C00" CornerRadius="4" Padding="6,2" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Type}" Foreground="{DynamicResource PrimaryAccent}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding ScheduleType, StringFormat='Freq: {0}'}" Foreground="{DynamicResource TextSecondary}" FontSize="9" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding ScheduleTime, StringFormat='Hora: {0}'}" Foreground="{DynamicResource TextSecondary}" FontSize="9" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Content="Iniciar Cópia Selecionada" Style="{DynamicResource AccentButton}" Width="180" Command="{Binding RunJobCommand}" Margin="0,0,10,0" />
                    <Button Content="Eliminar Tarefa" Background="{DynamicResource ErrorColor}" BorderBrush="{DynamicResource ErrorColor}" Width="130" Command="{Binding DeleteJobCommand}" />
                </StackPanel>
            </Grid>

            <!-- Add New Backup Job Panel (Right) -->
            <Border Grid.Column="1" Style="{DynamicResource GlassCard}" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Criar Nova Cópia" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Name -->
                            <TextBlock Text="Nome da Cópia:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4" />
                            <TextBox Text="{Binding NewJobName, UpdateSourceTrigger=PropertyChanged}" Background="#10FFFFFF" BorderBrush="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}" Padding="6" Margin="0,0,0,12" />

                            <!-- Type -->
                            <TextBlock Text="Tipo de Backup:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4" />
                            <ComboBox SelectedValue="{Binding NewJobType}" SelectedValuePath="Content" Background="#182C48" BorderBrush="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12">
                                <ComboBoxItem Content="Full" IsSelected="True" />
                                <ComboBoxItem Content="Incremental" />
                                <ComboBoxItem Content="Differential" />
                            </ComboBox>

                            <!-- Source Path -->
                            <TextBlock Text="Diretório/Caminho Origem:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4" />
                            <TextBox Text="{Binding NewSourcePath, UpdateSourceTrigger=PropertyChanged}" Background="#10FFFFFF" BorderBrush="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}" Padding="6" Margin="0,0,0,12" />

                            <!-- Target Path -->
                            <TextBlock Text="Diretório Destino:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4" />
                            <TextBox Text="{Binding NewDestinationPath, UpdateSourceTrigger=PropertyChanged}" Background="#10FFFFFF" BorderBrush="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}" Padding="6" Margin="0,0,0,12" />

                            <!-- Schedule Type -->
                            <TextBlock Text="Agendamento:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4" />
                            <ComboBox SelectedValue="{Binding NewScheduleType}" SelectedValuePath="Content" Background="#182C48" BorderBrush="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12">
                                <ComboBoxItem Content="Manual" IsSelected="True" />
                                <ComboBoxItem Content="Daily" />
                                <ComboBoxItem Content="Weekly" />
                                <ComboBoxItem Content="Monthly" />
                            </ComboBox>

                            <!-- Schedule Time -->
                            <TextBlock Text="Hora de Execução (HH:mm):" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4" />
                            <TextBox Text="{Binding NewScheduleTime}" Background="#10FFFFFF" BorderBrush="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}" Padding="6" Margin="0,0,0,10" />
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="Salvar Agendamento" Style="{DynamicResource AccentButton}" Command="{Binding SaveJobCommand}" Margin="0,10,0,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- Running Backup Progress Panel (Bottom) -->
        <Border Grid.Row="1" Padding="15" Margin="0,15,0,0" Background="#1500BFFF">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBackupRunning}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding CurrentOpText, FallbackValue='Archiving files...'}" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SpeedText, FallbackValue='45.1 MB/s'}" Foreground="{DynamicResource PrimaryAccent}" FontSize="12" FontWeight="Bold" />

                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Height="14" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}">
                        <ProgressBar.Foreground>
                            <SolidColorBrush Color="#FF8C00" />
                        </ProgressBar.Foreground>
                    </ProgressBar>
                    <Button Grid.Column="1" Content="Cancelar" Margin="10,0,0,0" Height="20" Padding="10,0" FontSize="10" Command="{Binding CancelBackupCommand}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
