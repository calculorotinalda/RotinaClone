<Window x:Class="RotinaClone.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vms="clr-namespace:RotinaClone.App.ViewModels"
        xmlns:views="clr-namespace:RotinaClone.App.Views"
        mc:Ignorable="d"
        Title="Rotina Clone - Enterprise Edition" 
        Height="680" Width="1050"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="Transparent">

    <Window.Resources>
        <!-- Map ViewModels to Views using DataTemplates -->
        <DataTemplate DataType="{x:Type vms:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:CloneWizardViewModel}">
            <views:CloneWizardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:BackupManagerViewModel}">
            <views:BackupManagerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:WinPeCreatorViewModel}">
            <views:WinPeCreatorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:LogViewModel}">
            <views:LogView />
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBackgroundGradient}" CornerRadius="12" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1.5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation Panel (Left) -->
            <Border Grid.Column="0" Background="#10000000" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,1.5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80" /> <!-- Logo/Brand -->
                        <RowDefinition Height="*" />    <!-- Navigation Items -->
                        <RowDefinition Height="60" />   <!-- Footer Version -->
                    </Grid.RowDefinitions>

                    <!-- App Title / Logo -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Simulated logo mark -->
                        <Grid Width="32" Height="32" Margin="0,0,10,0">
                            <Ellipse Fill="{DynamicResource PrimaryAccent}" />
                            <Path Data="M 12,20 L 20,20 L 20,12 Z" Fill="{DynamicResource TextDark}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Path Data="M 10,10 L 18,10 L 14,16 Z" Fill="{DynamicResource TextDark}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel>
                            <TextBlock Text="ROTINA CLONE" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="ExtraBold" />
                            <TextBlock Text="ENTERPRISE EDITION" Foreground="{DynamicResource PrimaryAccent}" FontSize="9" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Navigation Sidebar Buttons -->
                    <StackPanel Grid.Row="1" Margin="0,20,0,0">
                        <RadioButton Content="Painel Principal" Style="{StaticResource SidebarButton}" IsChecked="True"
                                     Command="{Binding NavigateCommand}" CommandParameter="Dashboard" />
                        
                        <RadioButton Content="Clonagem de Disco" Style="{StaticResource SidebarButton}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Clone" />
                        
                        <RadioButton Content="Cópia de Segurança" Style="{StaticResource SidebarButton}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Backup" />
                        
                        <RadioButton Content="Criador de WinPE" Style="{StaticResource SidebarButton}"
                                     Command="{Binding NavigateCommand}" CommandParameter="WinPE" />

                        <RadioButton Content="Logs de Sistema" Style="{StaticResource SidebarButton}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Logs" />
                        
                        <RadioButton Content="Definições" Style="{StaticResource SidebarButton}"
                                     Command="{Binding NavigateCommand}" CommandParameter="Settings" />
                    </StackPanel>

                    <!-- Sidebar Footer -->
                    <TextBlock Grid.Row="2" Text="v1.0.0 Stable (x64)" Foreground="{DynamicResource TextSecondary}" 
                               FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Main Display Area (Right) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" /> <!-- Custom Title Bar -->
                    <RowDefinition Height="*" />  <!-- Page Content -->
                    <RowDefinition Height="Auto" /> <!-- Status Bar -->
                </Grid.RowDefinitions>

                <!-- Header / Title Bar Drag Area -->
                <Border Grid.Row="0" Background="Transparent" x:Name="TitleBar" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="Solução Profissional de Clonagem e Backup" Foreground="{DynamicResource TextSecondary}" 
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="20,0,0,0" />
                        
                        <!-- Window Controls (Minimize / Close) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                            <!-- Minimize Button -->
                            <Button Content="—" FontSize="11" Width="30" Height="25" Background="Transparent" BorderThickness="0" Margin="0,0,5,0"
                                    Foreground="{DynamicResource TextSecondary}" Click="MinimizeButton_Click" />
                            <Button Content="▢" FontSize="11" Width="30" Height="25" Background="Transparent" BorderThickness="0" Margin="0,0,5,0"
                                    Foreground="{DynamicResource TextSecondary}" Click="MaximizeButton_Click" />
                            <Button Content="✕" FontSize="12" Width="30" Height="25" Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondary}" Click="CloseButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dynamic Content Host Page -->
                 <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" Margin="20,0,20,20" />
                 <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondary}" FontSize="12" Padding="5" TextWrapping="Wrap" Background="{DynamicResource WindowBackgroundGradient}" />
            </Grid>
        </Grid>
    </Border>
</Window>
