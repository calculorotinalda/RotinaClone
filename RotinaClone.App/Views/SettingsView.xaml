<UserControl x:Class="RotinaClone.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vms="clr-namespace:RotinaClone.App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vms:SettingsViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Definições Gerais de Rotina Clone" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="550" HorizontalAlignment="Left">
                <!-- Appearance Theme Settings -->
                <Border Style="{DynamicResource GlassCard}" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tema Escuro Premium (Dark Mode)" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="Bold" />
                            <TextBlock Text="Alternar entre o design escuro e o claro." Foreground="{DynamicResource TextSecondary}" FontSize="10" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Width="50" Height="24" IsChecked="{Binding IsDarkMode}" Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="BackgroundBorder" CornerRadius="12" Background="#30FFFFFF" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}">
                                        <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="{DynamicResource PrimaryAccent}" HorizontalAlignment="Left" Margin="2,0" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#15FF8C00" />
                                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </Grid>
                </Border>

                <!-- Safety Simulation Settings -->
                <Border Style="{DynamicResource GlassCard}" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Simulação de Segurança" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="Bold" />
                            <TextBlock Text="Impede a gravação real de setores para proteção contra formatações indesejadas." Foreground="{DynamicResource TextSecondary}" FontSize="10" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Width="50" Height="24" IsChecked="{Binding IsSimulationMode}" Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="BackgroundBorder" CornerRadius="12" Background="#30FFFFFF" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}">
                                        <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="{DynamicResource PrimaryAccent}" HorizontalAlignment="Left" Margin="2,0" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#15FF8C00" />
                                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </Grid>
                </Border>

                <!-- Email Notifications Settings -->
                <Border Style="{DynamicResource GlassCard}" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Notificações por E-mail" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Text="Receber relatórios automáticos de conclusão ou falhas no e-mail corporativo." Foreground="{DynamicResource TextSecondary}" FontSize="10" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1" Width="50" Height="24" IsChecked="{Binding IsEmailEnabled}" Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="BackgroundBorder" CornerRadius="12" Background="#30FFFFFF" BorderThickness="1" BorderBrush="{DynamicResource CardBorder}">
                                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="{DynamicResource PrimaryAccent}" HorizontalAlignment="Left" Margin="2,0" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#15FF8C00" />
                                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>

                        <StackPanel IsEnabled="{Binding IsEmailEnabled}">
                            <TextBlock Text="Servidor SMTP:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4" />
                            <TextBox Text="{Binding SmtpServer}" Background="#10FFFFFF" BorderBrush="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}" Padding="6" Margin="0,0,0,12" />

                            <TextBlock Text="E-mail de Destino:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4" />
                            <TextBox Text="{Binding SmtpEmail}" Background="#10FFFFFF" BorderBrush="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}" Padding="6" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
