<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Core Palette -->
    <Color x:Key="WindowBgColor1">#F5F7FA</Color>
    <Color x:Key="WindowBgColor2">#E4E9F0</Color>
    
    <SolidColorBrush x:Key="WindowBackground" Color="#F5F7FA" />
    <LinearGradientBrush x:Key="WindowBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F5F7FA" Offset="0" />
        <GradientStop Color="#E4E9F0" Offset="0.5" />
        <GradientStop Color="#D5DCE8" Offset="1" />
    </LinearGradientBrush>

    <!-- Card Brushes -->
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBorder" Color="#D1D9E6" />
    <SolidColorBrush x:Key="CardHeaderBackground" Color="#EDF1F6" />

    <!-- Interactive Colors -->
    <Color x:Key="PrimaryAccentColor">#FF8C00</Color>
    <Color x:Key="PrimaryAccentHoverColor">#FF6A00</Color>
    <Color x:Key="InfoColorValue">#0D4C92</Color>
    <Color x:Key="SuccessColorValue">#4CAF50</Color>
    <Color x:Key="ErrorColorValue">#F44336</Color>

    <!-- Interactive Brushes -->
    <SolidColorBrush x:Key="PrimaryAccent" Color="{DynamicResource PrimaryAccentColor}" />
    <SolidColorBrush x:Key="PrimaryAccentHover" Color="{DynamicResource PrimaryAccentHoverColor}" />
    <SolidColorBrush x:Key="InfoColor" Color="{DynamicResource InfoColorValue}" />
    <SolidColorBrush x:Key="SuccessColor" Color="{DynamicResource SuccessColorValue}" />
    <SolidColorBrush x:Key="ErrorColor" Color="{DynamicResource ErrorColorValue}" />

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimary" Color="#1E2835" />
    <SolidColorBrush x:Key="TextSecondary" Color="#5F7085" />
    <SolidColorBrush x:Key="TextDark" Color="#FFFFFF" />

    <!-- Button Brushes -->
    <SolidColorBrush x:Key="ButtonBackground" Color="#E8EFF9" />
    <SolidColorBrush x:Key="ButtonBorder" Color="#D1D9E6" />
    <SolidColorBrush x:Key="ButtonHover" Color="{DynamicResource PrimaryAccentColor}" />

</ResourceDictionary>
