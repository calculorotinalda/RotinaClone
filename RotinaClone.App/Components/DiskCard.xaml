<UserControl x:Class="RotinaClone.App.Components.DiskCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignWidth="600" d:DesignHeight="180"
             Margin="0,0,0,15">
    <Grid>
        <Border Style="{DynamicResource GlassCard}" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Disk Info Header -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Disk Icon + Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- Disk Icon (Simulated with simple vector shape) -->
                        <Grid Width="24" Height="24" Margin="0,0,10,0">
                            <Ellipse Fill="{DynamicResource PrimaryAccent}" Opacity="0.1" />
                            <Path Data="M4,4 H20 V20 H4 Z M6,6 H18 V10 H6 Z M6,12 H18 V18 H6 Z" 
                                  Stroke="{DynamicResource PrimaryAccent}" StrokeThickness="1.5" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        
                        <StackPanel>
                            <TextBlock Text="{Binding Model, FallbackValue='SAMSUNG SSD 980 PRO 1TB'}" 
                                       Foreground="{DynamicResource TextPrimary}" 
                                       FontSize="15" FontWeight="Bold" />
                            <TextBlock Text="{Binding SerialNumber, StringFormat='S/N: {0}', FallbackValue='S62WNJ0R102938X'}" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Disk Meta Info -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1500BFFF" BorderBrush="#3000BFFF" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                            <TextBlock Text="{Binding InterfaceType, FallbackValue='NVMe'}" Foreground="{DynamicResource InfoColor}" FontSize="11" FontWeight="Bold" />
                        </Border>
                        <Border Background="#15FF8C00" BorderBrush="#30FF8C00" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                            <TextBlock Text="{Binding PartitionStyle, FallbackValue='GPT'}" Foreground="{DynamicResource PrimaryAccent}" FontSize="11" FontWeight="Bold" />
                        </Border>
                        <TextBlock Text="{Binding TotalSizeGB, StringFormat='{}{0:F1} GB', FallbackValue='931.5 GB'}" 
                                   Foreground="{DynamicResource TextPrimary}" 
                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Partition Visualizer Grid -->
                <Border Grid.Row="1" Background="#10FFFFFF" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Height="55" Margin="0,5">
                    <Grid x:Name="PartitionGrid">
                        <!-- Populated programmatically in code-behind -->
                    </Grid>
                </Border>

                <!-- Disk Health and Stats Footer -->
                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Health Indicator -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Saúde: " Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                        <Ellipse Width="8" Height="8" Margin="5,0" x:Name="HealthIndicatorDot" Fill="{DynamicResource SuccessColor}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding HealthStatus, FallbackValue='Saudável (100%)'}" x:Name="HealthText" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>

                    <!-- Temperature -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Temp: " Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                        <TextBlock Text="{Binding Temperature, StringFormat='{}{0}°C', FallbackValue='34°C'}" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
